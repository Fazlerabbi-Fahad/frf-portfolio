# Backend API base URL (no trailing slash). In production, your Render/Railway URL + /api
VITE_API_BASE=http://localhost:5000/api

# Cloudinary — create a free account, then an UNSIGNED upload preset
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset

# Your production domain (for SEO canonical + OG URLs)
VITE_SITE_URL=https://your-domain.vercel.app
